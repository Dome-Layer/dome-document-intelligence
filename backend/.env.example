# LLM
LLM_PROVIDER=claude
# Model string. Override to swap models without code changes.
LLM_TEXT_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=

# Azure OpenAI (enterprise deployments)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=

# Ollama (air-gapped deployments)
OLLAMA_URL=http://localhost:11434

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
ENVIRONMENT=production
CORS_ORIGINS=https://document-intelligence.domelayer.com
MAX_FILE_SIZE_MB=20

# Local development only — set to true to skip Supabase JWT validation
# NEVER set to true in production
DEV_BYPASS_AUTH=false
