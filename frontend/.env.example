NEXT_PUBLIC_API_BASE=https://your-railway-backend.up.railway.app
# Auth backend URL — the DOME website that handles magic link authentication (e.g. https://domelayer.com)
NEXT_PUBLIC_AUTH_BACKEND=https://domelayer.com
NEXT_PUBLIC_SITE_URL=https://document-intelligence.domelayer.com

# Local development only — set to true to skip SSO auth check
# NEVER set to true in production
NEXT_PUBLIC_SKIP_AUTH=false
